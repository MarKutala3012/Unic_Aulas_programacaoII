package exercicios_heranc;
public class Exercicios_heranc {
    public static void main(String[] args) {
        Produto produtoNormal = new Produto("Televisao", 200, "TV001");
        ProdutoPerecivel produtoPerecivel = new ProdutoPerecivel("Leite", 100, "LT001", 1);

        double iva = 0.14; // 14% IVA

        double precoNormal = produtoNormal.calcularPreco(iva);
        double precoPerecivel = produtoPerecivel.calcularPreco(iva);

        System.out.println("Produto: " + produtoNormal.getNome() +
                " | Preco final: " + precoNormal);

        System.out.println("Produto Perecivel: " + produtoPerecivel.getNome() +
                " | Preco final: " + precoPerecivel);
    }
}
       
    




